export default function sequenceActions(reasonerOutput) {
  let actions = [];

  if (!reasonerOutput) return actions;

  if (reasonerOutput.hard_blockers && reasonerOutput.hard_blockers.some(b => b.includes('lockout'))) {
    actions.push({
      action: 'File emergency stay of eviction in court.',
      urgency: 'TODAY',
      effort: 'HIGH',
      unlocks: 'Pauses eviction process, buying time for legal defense.',
      source_rule: 'evic_1'
    });
  }

  if (reasonerOutput.soft_blockers && reasonerOutput.soft_blockers.some(b => b.includes('Safety risk'))) {
    actions.push({
      action: 'Contact local domestic violence hotline for safety planning.',
      urgency: 'TODAY',
      effort: 'LOW',
      unlocks: 'Ensures physical safety before addressing housing.',
      source_rule: 'dv_1'
    });
  }
  
  if (reasonerOutput.hidden_flags && reasonerOutput.hidden_flags.some(b => b.includes('VAWA'))) {
     actions.push({
      action: 'Submit VAWA self-certification form to landlord.',
      urgency: 'THIS WEEK',
      effort: 'LOW',
      unlocks: 'Prevents eviction based on abuse-related incidents.',
      source_rule: 'dv_1'
    });
  }

  if (reasonerOutput.hidden_flags && reasonerOutput.hidden_flags.some(b => b.includes('legally served'))) {
    actions.push({
      action: 'Review eviction notice for legal defects.',
      urgency: 'THIS WEEK',
      effort: 'MEDIUM',
      unlocks: 'Potential dismissal of eviction case.',
      source_rule: 'evic_1'
    });
  }

  if (reasonerOutput.hard_blockers && reasonerOutput.hard_blockers.some(b => b.includes('losing voucher'))) {
    actions.push({
      action: 'Request grievance hearing with housing authority.',
      urgency: 'THIS WEEK',
      effort: 'MEDIUM',
      unlocks: 'Preserves Section 8 voucher status.',
      source_rule: 'sec8_1'
    });
  }

  if (reasonerOutput.soft_blockers && reasonerOutput.soft_blockers.some(b => b.includes('rental assistance'))) {
    actions.push({
      action: 'Gather documents and apply for Emergency Rental Assistance.',
      urgency: 'THIS MONTH',
      effort: 'HIGH',
      unlocks: 'Pays back rent to resolve financial trigger.',
      source_rule: 'era_1'
    });
  }

  // Fallback actions if array is empty
  if (actions.length === 0) {
    actions.push({
      action: 'Consult with legal aid or housing counselor.',
      urgency: 'THIS WEEK',
      effort: 'MEDIUM',
      unlocks: 'Provides expert guidance on specific situation.',
      source_rule: 'general'
    });
  }

  // Sort by urgency then effort
  const urgencyWeight = { 'TODAY': 1, 'THIS WEEK': 2, 'THIS MONTH': 3 };
  const effortWeight = { 'LOW': 1, 'MEDIUM': 2, 'HIGH': 3 };

  actions.sort((a, b) => {
    if (urgencyWeight[a.urgency] !== urgencyWeight[b.urgency]) {
      return urgencyWeight[a.urgency] - urgencyWeight[b.urgency];
    }
    return effortWeight[a.effort] - effortWeight[b.effort];
  });

  // Assign ranks and slice to max 7
  actions = actions.slice(0, 7).map((item, index) => ({
    rank: index + 1,
    ...item
  }));

  return actions;
}
