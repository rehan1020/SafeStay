import calibrateStress from './stressCalibrator.js';
import parseSituation from './situationParser.js';
import reasonProfile from './caseworkerReasoner.js';
import sequenceActions from './actionSequencer.js';

export const intakeAgent = {
    async process(text, data) {
        // Evaluate stress level (used internally to guide follow-up pacing)
        const stressMode = calibrateStress(text);
        
        // Combine history for parsing
        const combinedInput = data.join('\\n');
        const profile = parseSituation(combinedInput);

        // Required minimum fields: urgency, trigger, housing_type
        const hasMinimum = !profile.missing_fields.includes('urgency') && 
                           !profile.missing_fields.includes('trigger') && 
                           !profile.missing_fields.includes('housing_type');

        if (hasMinimum) {
            return { sufficientData: true };
        } else {
            // Ask for missing fields based on stress mode pacing
            let followUp = "I need a bit more info to help you. ";
            if (profile.missing_fields.includes('trigger')) {
                followUp += "What specific event happened (e.g., received an eviction notice, lost job)? ";
                if (stressMode === 'CRISIS') return { sufficientData: false, followUpQuestion: followUp };
            }
            if (profile.missing_fields.includes('urgency')) {
                followUp += "When do you need to take action or move by? ";
                if (stressMode === 'CRISIS' || stressMode === 'NORMAL') return { sufficientData: false, followUpQuestion: followUp };
            }
            if (profile.missing_fields.includes('housing_type')) {
                followUp += "Are you renting an apartment/house, in subsidized housing, or something else? ";
            }
            return { sufficientData: false, followUpQuestion: followUp.trim() };
        }
    }
};

export const processingAgent = {
    async analyze(combinedInput) {
        // Run the pipeline
        const profile = parseSituation(combinedInput);
        const reasonerOutput = reasonProfile(profile);
        const actionPlan = sequenceActions(reasonerOutput);

        // Format the output for the renderer
        return {
            summary: `Your situation involves a ${profile.trigger || 'housing issue'} requiring action within ${profile.urgency || 'a certain timeframe'}.`,
            faultMap: buildFaultMap(reasonerOutput),
            missed: reasonerOutput.hidden_flags || [],
            disqualifiers: reasonerOutput.disqualifier_risks || [],
            actionPlan: actionPlan,
            isDomesticViolence: profile.trigger === 'DOMESTIC_VIOLENCE'
        };
    }
};

function buildFaultMap(reasonerOutput) {
    let map = "[YOUR SITUATION]\\n";
    
    if (reasonerOutput.hard_blockers && reasonerOutput.hard_blockers.length > 0) {
        reasonerOutput.hard_blockers.forEach(blocker => {
            map += `  → [BLOCKER: ${blocker}] — impact: HARD\\n`;
            map += `      ↳ BYPASS: Requires legal intervention\\n`;
        });
    }
    
    if (reasonerOutput.soft_blockers && reasonerOutput.soft_blockers.length > 0) {
         reasonerOutput.soft_blockers.forEach(blocker => {
            map += `  → [BLOCKER: ${blocker}] — impact: SOFT\\n`;
            map += `      ↳ BYPASS: Workaround may be available\\n`;
        });
    }

    if (map === "[YOUR SITUATION]\\n") {
        map += "  → [STATUS: Standard pathways appear accessible]\\n";
        map += "      ↳ NEXT STEP: Proceed with action plan\\n";
    }

    map += "  → [EXIT: Legal interpretation required — see human referral below]\\n";
    return map;
}
