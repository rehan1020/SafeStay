export function renderResults(outputContainer, pipelineOutput) {
    // Clear previous results
    outputContainer.innerHTML = '';
    
    // Check for domestic violence to prepend disclaimer
    if (pipelineOutput.isDomesticViolence) {
        const safetyWarning = document.createElement('div');
        safetyWarning.className = 'result-section disclaimer-section danger-alert';
        safetyWarning.innerHTML = `
            <h2>🛡️ MANDATORY HUMAN REFERRAL</h2>
            <div class="legal-disclaimer">
                <p><strong>🛡️ If you are in immediate danger, contact emergency services first.</strong></p>
                <p>---</p>
                <p>⚖️ SafeStay does not make legal determinations.</p>
                <p>One or more steps above may require legal interpretation specific to your location.</p>
                <p>Next step: Contact a local housing legal aid organization or tenant rights service before taking any action marked HIGH effort or involving formal notices.</p>
                <p>This is not legal advice.</p>
                <p>---</p>
            </div>
        `;
        outputContainer.appendChild(safetyWarning);
    }

    // 1. SITUATION SUMMARY
    const summarySection = document.createElement('div');
    summarySection.className = 'result-section summary-section';
    summarySection.innerHTML = `
        <h2>1. SITUATION SUMMARY</h2>
        <p>${pipelineOutput.summary || 'Summary unavailable.'}</p>
    `;
    outputContainer.appendChild(summarySection);

    // 2. FAULT MAP (Node graph rendered nicely)
    const faultMapSection = document.createElement('div');
    faultMapSection.className = 'result-section fault-map-section';
    faultMapSection.innerHTML = `
        <h2>2. FAULT MAP</h2>
        <pre class="node-graph"><code>${pipelineOutput.faultMap}</code></pre>
    `;
    outputContainer.appendChild(faultMapSection);

    // 3. WHAT MOST PEOPLE MISS (⚠️ list)
    const missedSection = document.createElement('div');
    missedSection.className = 'result-section missed-section';
    const missedItems = (pipelineOutput.missed || []).slice(0, 3).map(item => `<li>⚠️ ${item}</li>`).join('');
    missedSection.innerHTML = `
        <h2>3. WHAT MOST PEOPLE MISS</h2>
        <ul class="warning-list">
            ${missedItems || '<li>⚠️ No hidden flags detected in standard analysis.</li>'}
        </ul>
    `;
    outputContainer.appendChild(missedSection);

    // 4. DISQUALIFIER WARNINGS (🚫 list)
    const disqualifierSection = document.createElement('div');
    disqualifierSection.className = 'result-section disqualifier-section';
    const disqualifierItems = (pipelineOutput.disqualifiers || []).slice(0, 3).map(item => `<li>🚫 Warning: ${item}</li>`).join('');
    disqualifierSection.innerHTML = `
        <h2>4. DISQUALIFIER WARNINGS</h2>
        <ul class="error-list">
            ${disqualifierItems || '<li>🚫 No immediate disqualifier risks detected.</li>'}
        </ul>
    `;
    outputContainer.appendChild(disqualifierSection);

    // 5. YOUR ACTION PLAN (Table)
    const actionPlanSection = document.createElement('div');
    actionPlanSection.className = 'result-section action-plan-section';
    
    let actionHTML = `
        <h2>5. YOUR ACTION PLAN</h2>
        <table class="action-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Action</th>
                    <th>When</th>
                    <th>Effort</th>
                    <th>Unlocks</th>
                </tr>
            </thead>
            <tbody>
    `;

    const sources = [];
    (pipelineOutput.actionPlan || []).forEach(step => {
        actionHTML += `
            <tr>
                <td>${step.rank}</td>
                <td>${step.action}</td>
                <td><span class="badge urgency-${step.urgency.replace(' ', '-').toLowerCase()}">${step.urgency}</span></td>
                <td><span class="badge effort-${step.effort.toLowerCase()}">${step.effort}</span></td>
                <td>${step.unlocks}</td>
            </tr>
        `;
        if (step.source_rule) sources.push(`📌 Source: ${step.source_rule}`);
    });

    actionHTML += `
            </tbody>
        </table>
        <div class="action-sources">
            ${sources.join('<br>')}
        </div>
    `;
    
    actionPlanSection.innerHTML = actionHTML;
    outputContainer.appendChild(actionPlanSection);

    // 6. MANDATORY HUMAN REFERRAL (Legal disclaimer, always present at bottom if not prepended)
    if (!pipelineOutput.isDomesticViolence) {
        const disclaimerSection = document.createElement('div');
        disclaimerSection.className = 'result-section disclaimer-section';
        disclaimerSection.innerHTML = `
            <h2>6. MANDATORY HUMAN REFERRAL</h2>
            <div class="legal-disclaimer">
                <p>---</p>
                <p>⚖️ SafeStay does not make legal determinations.</p>
                <p>One or more steps above may require legal interpretation specific to your location.</p>
                <p>Next step: Contact a local housing legal aid organization or tenant rights service before taking any action marked HIGH effort or involving formal notices.</p>
                <p>This is not legal advice.</p>
                <p>---</p>
            </div>
        `;
        outputContainer.appendChild(disclaimerSection);
    }
}
