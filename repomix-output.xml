<file path="js/agents/situationParser.js">
export default function parseSituation(text) {
  const result = {
    urgency: null,
    trigger: null,
    housing_type: null,
    income_status: null,
    dependents: null,
    locale_hint: null,
    missing_fields: []
  };

  if (!text || typeof text !== 'string') {
    result.missing_fields = ['urgency', 'trigger', 'housing_type'];
    return result;
  }

  const textLower = text.toLowerCase();

  // Parse urgency
  if (textLower.match(/today|now|tonight|immediately|emergency/)) {
    result.urgency = 'IMMEDIATE';
  } else if (textLower.match(/tomorrow|this week|soon|days/)) {
    result.urgency = 'HIGH';
  } else if (textLower.match(/month|weeks/)) {
    result.urgency = 'MEDIUM';
  } else {
    result.urgency = 'LOW';
  }

  // Parse trigger
  if (textLower.match(/evict|notice|court|summons/)) {
    result.trigger = 'EVICTION_NOTICE';
  } else if (textLower.match(/abuse|hit|scared|violent|restraining/)) {
    result.trigger = 'DOMESTIC_VIOLENCE';
  } else if (textLower.match(/rent|behind|pay|job|fired/)) {
    result.trigger = 'FINANCIAL_HARDSHIP';
  } else if (textLower.match(/condition|mold|rat|heat|water/)) {
    result.trigger = 'POOR_CONDITIONS';
  }

  // Parse housing_type
  if (textLower.match(/apartment|apt|flat/)) {
    result.housing_type = 'APARTMENT';
  } else if (textLower.match(/house|home/)) {
    result.housing_type = 'HOUSE';
  } else if (textLower.match(/section 8|voucher|public housing/)) {
    result.housing_type = 'SUBSIDIZED';
  } else if (textLower.match(/shelter|street|car/)) {
    result.housing_type = 'UNHOUSED';
  }

  // Parse income_status
  if (textLower.match(/lost job|fired|laid off|unemployed/)) {
    result.income_status = 'UNEMPLOYED';
  } else if (textLower.match(/working|job|paycheck|salary/)) {
    result.income_status = 'EMPLOYED';
  } else if (textLower.match(/ssi|disability|benefits/)) {
    result.income_status = 'BENEFITS';
  }

  // Parse dependents
  if (textLower.match(/kid|child|son|daughter|baby|toddler/)) {
    result.dependents = true;
  } else if (textLower.match(/alone|just me/)) {
    result.dependents = false;
  }

  // Parse locale
  const stateMatch = text.match(/\b([A-Z]{2})\b/);
  if (stateMatch) {
    result.locale_hint = stateMatch[1];
  }

  // Determine missing fields
  if (!result.urgency) result.missing_fields.push('urgency');
  if (!result.trigger) result.missing_fields.push('trigger');
  if (!result.housing_type) result.missing_fields.push('housing_type');

  return result;
}
