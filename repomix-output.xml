import { renderResults } from './renderer.js';
import { intakeAgent, processingAgent } from './agents/index.js';

const STATE = {
    LANDING: 'LANDING',
    INTAKE: 'INTAKE',
    PROCESSING: 'PROCESSING',
    RESULTS: 'RESULTS'
};

class App {
    constructor() {
        this.state = STATE.LANDING;
        this.intakeData = [];
        
        // DOM Elements
        this.heroSection = document.getElementById('hero-section');
        this.chatContainer = document.getElementById('chat-container');
        this.chatHistory = document.getElementById('chat-history');
        this.typingIndicator = document.getElementById('typing-indicator');
        this.inputArea = document.getElementById('input-area');
        this.chatForm = document.getElementById('chat-form');
        this.userInput = document.getElementById('user-input');
        this.outputContainer = document.getElementById('output-container');

        this.init();
    }

    init() {
        this.chatForm.addEventListener('submit', (e) => this.handleSubmit(e));
        
        this.userInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                this.chatForm.dispatchEvent(new Event('submit'));
            }
        });

        // Setup initial view
        this.updateView();
        
        // Start Intake after a brief delay
        setTimeout(() => {
            this.transitionTo(STATE.INTAKE);
        }, 1500);
    }

    transitionTo(newState) {
        this.state = newState;
        this.updateView();

        if (this.state === STATE.INTAKE && this.intakeData.length === 0) {
            this.addMessage("Hello! I'm SafeStay. Please describe the housing issue or tenancy situation you're facing in as much detail as possible.", 'system');
        } else if (this.state === STATE.PROCESSING) {
            this.processData();
        }
    }

    updateView() {
        switch (this.state) {
            case STATE.LANDING:
                this.heroSection.classList.remove('hidden');
                this.chatContainer.classList.add('hidden');
                this.inputArea.classList.add('hidden');
                this.outputContainer.classList.add('hidden');
                break;
            case STATE.INTAKE:
                this.heroSection.classList.add('hidden');
                this.chatContainer.classList.remove('hidden');
                this.inputArea.classList.remove('hidden');
                this.outputContainer.classList.add('hidden');
                break;
            case STATE.PROCESSING:
                this.inputArea.classList.add('hidden');
                this.showTypingIndicator();
                break;
            case STATE.RESULTS:
                this.hideTypingIndicator();
                this.chatContainer.classList.add('hidden');
                this.outputContainer.classList.remove('hidden');
                break;
        }
    }

    async handleSubmit(e) {
        if (e) e.preventDefault();
        
        const text = this.userInput.value.trim();
        if (!text) return;

        this.userInput.value = '';
        this.addMessage(text, 'user');
        this.intakeData.push(text);

        if (this.state === STATE.INTAKE) {
            this.showTypingIndicator();
            try {
                // Call the intake agent to see if we have enough info
                const intakeResponse = await intakeAgent.process(text, this.intakeData);
                this.hideTypingIndicator();
                
                if (intakeResponse.sufficientData) {
                    this.addMessage("Thank you. I have enough information. I am now analyzing your case...", 'system');
                    this.transitionTo(STATE.PROCESSING);
                } else {
                    this.addMessage(intakeResponse.followUpQuestion || "Could you provide a bit more detail?", 'system');
                }
            } catch (error) {
                this.hideTypingIndicator();
                console.warn("Intake agent error:", error);
                this.addMessage("Thank you. I am now analyzing your case...", 'system');
                this.transitionTo(STATE.PROCESSING);
            }
        }
    }

    async processData() {
        try {
            const combinedInput = this.intakeData.join('\\n');
            const pipelineOutput = await processingAgent.analyze(combinedInput);
            renderResults(this.outputContainer, pipelineOutput);
            this.transitionTo(STATE.RESULTS);
        } catch (error) {
            console.error("Processing agent error:", error);
            this.outputContainer.innerHTML = '<p>Error generating results. Please try again.</p>';
            this.transitionTo(STATE.RESULTS);
        }
    }

    addMessage(text, sender) {
        const msgDiv = document.createElement('div');
        msgDiv.className = \`message \${sender}-message\`;
        msgDiv.textContent = text;
        this.chatHistory.appendChild(msgDiv);
        this.chatHistory.scrollTop = this.chatHistory.scrollHeight;
    }

    showTypingIndicator() {
        this.typingIndicator.classList.remove('hidden');
        this.chatHistory.scrollTop = this.chatHistory.scrollHeight;
    }

    hideTypingIndicator() {
        this.typingIndicator.classList.add('hidden');
    }
}

// Initialize app on load
document.addEventListener('DOMContentLoaded', () => {
    window.app = new App();
});
