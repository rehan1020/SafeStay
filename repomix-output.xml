import { rules } from '../knowledgeBase.js';

export default function reasonProfile(profile) {
  const result = {
    hard_blockers: [],
    soft_blockers: [],
    hidden_flags: [],
    disqualifier_risks: []
  };

  if (!profile) return result;

  // Evaluate Eviction
  if (profile.trigger === 'EVICTION_NOTICE') {
    if (profile.urgency === 'IMMEDIATE') {
      result.hard_blockers.push('Imminent lockout risk. Immediate legal intervention required.');
    }
    result.hidden_flags.push('Check if notice was legally served.');
    result.disqualifier_risks.push('Default judgment if court date missed.');
  }

  // Evaluate Domestic Violence
  if (profile.trigger === 'DOMESTIC_VIOLENCE') {
    result.soft_blockers.push('Safety risk may prevent standard communication.');
    result.hidden_flags.push('VAWA protections apply if federally subsidized.');
    if (profile.housing_type === 'SUBSIDIZED') {
      result.disqualifier_risks.push('Abuser might be head of household.');
    }
  }

  // Evaluate Financial Hardship / ERA
  if (profile.trigger === 'FINANCIAL_HARDSHIP' || profile.income_status === 'UNEMPLOYED') {
    result.soft_blockers.push('Missing documentation could delay rental assistance.');
    result.disqualifier_risks.push('Income might exceed local ERA limits if previously high-earning.');
  }

  // Evaluate Subsidized Housing
  if (profile.housing_type === 'SUBSIDIZED') {
    result.hard_blockers.push('Risk of losing voucher if evicted for cause.');
    result.hidden_flags.push('Must request grievance hearing quickly.');
  }

  // Dependents
  if (profile.dependents) {
    result.hidden_flags.push('Child Protective Services risk if becoming unhoused.');
    result.soft_blockers.push('Requires family-sized shelter space, which is scarce.');
  }

  return result;
}
