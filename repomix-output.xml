@import 'fonts.css';

:root {
  /* Base Colors */
  --bg-base: #0a0a0f;
  --bg-panel: rgba(20, 20, 30, 0.4);
  --bg-panel-hover: rgba(30, 30, 45, 0.5);

  /* Typography */
  --text-main: #f3f4f6;
  --text-muted: #9ca3af;
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;

  /* Accents and States */
  --accent-teal: #0ff0b3;
  --accent-blue: #4f9cf7;
  --gradient-accent: linear-gradient(135deg, var(--accent-teal), var(--accent-blue));
  --warning-amber: #f59e0b;
  --danger-red: #ef4444;
  --success-green: #10b981;

  /* Glassmorphism */
  --glass-blur: blur(16px);
  --glass-border: rgba(255, 255, 255, 0.08);
  --glass-border-luminous: rgba(15, 240, 179, 0.2);
  --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);

  /* Layout */
  --radius-lg: 1.5rem;
  --radius-md: 1rem;
  --radius-sm: 0.5rem;
  --container-max: 800px;
}

/* Reset & Base Styles */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-base);
  color: var(--text-main);
  font-family: var(--font-sans);
  line-height: 1.6;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1rem;
  overflow-x: hidden;
  /* Add subtle background ambient glow */
  background-image:
    radial-gradient(circle at 15% 50%, rgba(15, 240, 179, 0.05), transparent 25%),
    radial-gradient(circle at 85% 30%, rgba(79, 156, 247, 0.05), transparent 25%);
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  font-weight: 600;
  line-height: 1.2;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

/* Glassmorphic Panel Component */
.glass-panel {
  background: var(--bg-panel);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--glass-shadow);
  padding: 1.5rem;
  transition: all 0.3s ease;
}

.glass-panel:hover {
  border-color: var(--glass-border-luminous);
  background: var(--bg-panel-hover);
}

/* Main Container */
.app-container {
  width: 100%;
  max-width: var(--container-max);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

/* Chat Interface */
.chat-container {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  height: 60vh;
  overflow-y: auto;
  padding: 1rem 0;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.2) transparent;
}

.chat-container::-webkit-scrollbar {
  width: 6px;
}
.chat-container::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.2);
  border-radius: 10px;
}

.chat-bubble {
  max-width: 85%;
  padding: 1rem 1.25rem;
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  animation: fadeUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
  transform: translateY(10px);
}

.chat-bubble.user {
  align-self: flex-end;
  background: var(--gradient-accent);
  color: #000;
  font-weight: 500;
  border-bottom-right-radius: 4px;
  box-shadow: 0 4px 15px rgba(15, 240, 179, 0.15);
}

.chat-bubble.system {
  align-self: flex-start;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--glass-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-bottom-left-radius: 4px;
}

/* Fault Map Section */
.fault-map {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: 1.5rem;
  color: var(--accent-teal);
  overflow-x: auto;
  position: relative;
  box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
}

.fault-map::before {
  content: 'System.Diagnostics.Graph';
  display: block;
  color: var(--text-muted);
  font-size: 0.75rem;
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border-bottom: 1px solid var(--glass-border);
  padding-bottom: 0.75rem;
}

.node-warning { color: var(--warning-amber); }
.node-danger { color: var(--danger-red); }
.node-safe { color: var(--accent-teal); }
.node-connection { color: var(--glass-border); }

/* Typing Indicator Animation */
.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 1rem 1.25rem;
  align-items: center;
  width: fit-content;
}

.dot {
  width: 6px;
  height: 6px;
  background-color: var(--text-muted);
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* Entrance Animation */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Utilities */
.text-gradient {
  background: var(--gradient-accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Mobile First Responsive */
@media (min-width: 640px) {
  body {
    padding: 2rem;
  }
  .app-container {
    padding: 2rem;
  }
  .chat-bubble {
    max-width: 70%;
  }
}
